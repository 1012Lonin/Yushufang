# =====================================================
# Yushufang (御书房) 环境变量模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# =====================================================

# ---- LLM API Keys（多 Provider）----
# Anthropic（内阁、兵部、都察院、翰林院掌院、吏部）
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI（司礼监、工部、刑部）
OPENAI_API_KEY=sk-openai-xxx

# DeepSeek（户部、礼部、典簿司、起居注官）
DEEPSEEK_API_KEY=sk-deepseek-xxx

# ---- Discord Bot Tokens（每个 agent 一个）----
DISCORD_SILIJIAN_TOKEN=xxx
DISCORD_NEIGE_TOKEN=xxx
DISCORD_BINGBU_TOKEN=xxx
DISCORD_DUICHAYUAN_TOKEN=xxx
DISCORD_HUBU_TOKEN=xxx
DISCORD_LIBU_TOKEN=xxx
DISCORD_GONGBU_TOKEN=xxx
DISCORD_LIBU2_TOKEN=xxx
DISCORD_XINGBU_TOKEN=xxx
DISCORD_HANLIN_ZHANG_TOKEN=xxx

# 按需开启（论文流水线 / 生活辅助）
DISCORD_HANLIN_XIUZHUAN_TOKEN=xxx
DISCORD_HANLIN_BIANXIU_TOKEN=xxx
DISCORD_HANLIN_JIANTAO_TOKEN=xxx
DISCORD_HANLIN_SHUJISHI_TOKEN=xxx
DISCORD_DIANBOSI_TOKEN=xxx
DISCORD_QIJUZHU_TOKEN=xxx
DISCORD_GUOZIJIAN_TOKEN=xxx
DISCORD_TAIYIYUAN_TOKEN=xxx
DISCORD_NEIWUFU_TOKEN=xxx
DISCORD_YUSHANFANG_TOKEN=xxx

# ---- Discord 服务器 ID ----
DISCORD_SERVER_ID=xxx

# ---- GUI 认证 ----
BOLUO_AUTH_TOKEN=your-random-auth-token

# ---- 户部月度 token 限制（用于 Shell 脚本阈值计算）----
HUBU_MONTHLY_LIMIT=5000000
